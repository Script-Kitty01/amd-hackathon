# Local development only. NEVER commit real keys or bundle this in the image.
# The grading harness injects the real values at evaluation time.

FIREWORKS_API_KEY=your-dev-key-here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Track 1 allowed models (published at launch; harness injects the real list):
#   minimax-m3, kimi-k2p7-code, gemma-4-31b-it, gemma-4-26b-a4b-it, gemma-4-31b-it-nvfp4
# Fallback selection prefers kimi-k2p7-code for code and minimax-m3 for reasoning
# (see src/categories.py MODEL_HINTS); the sweep can override per category.
ALLOWED_MODELS=minimax-m3,kimi-k2p7-code,gemma-4-31b-it,gemma-4-26b-a4b-it,gemma-4-31b-it-nvfp4
# If a fallback model is a "thinking" model, set FIREWORKS_REASONING_EFFORT=none
# to avoid hidden reasoning tokens truncating answers / inflating cost.
# FIREWORKS_REASONING_EFFORT=none

# Optional local overrides (defaults target the container paths /input, /output)
INPUT_PATH=data/input/tasks.json
OUTPUT_PATH=data/output/results.json
RUNTIME_BUDGET_SECONDS=540

# Local LLM tier — DISABLED in the shipped image. A 2-3B model that fits the
# 4 GB CPU grading box is too weak to clear the accuracy gate, so the submitted
# container is two-tier: deterministic solvers (free) + Fireworks. These vars
# are left unset in production (the cascade skips the local-LLM tier). For dev
# experiments you may point them at a local Ollama endpoint; not used at grading.
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3.2:3b
# LOCAL_LLM_API_KEY=local
# LOCAL_LLM_SAMPLES=1

# Optional launch-day tuning files (defaults shown):
# MODEL_PREFERENCE_PATH=config/model_preference.json
# CONFIDENCE_PATH=config/confidence.json
